// Export GEOBoarders
var path = "FAO/GAUL_SIMPLIFIED_500m/2015/level0"; // Set the path to the GAUL dataset, which contains simplified country borders at 500m resolution in 2015.
var country_code = 132; // Set the country code for Kazakhstan.
var country = ee.FeatureCollection(path).filter(ee.Filter.eq('ADM0_CODE', country_code)); // Filter the country feature collection for Kazakhstan.

var collection = ee.ImageCollection('NASA/GDDP-CMIP6').filter(ee.Filter.eq('scenario', 'historical'));
var models = ['ACCESS-CM2', 'ACCESS-ESM1-5', 'BCC-CSM2-MR', 'CESM2', 'CESM2-WACCM', 'CMCC-CM2-SR5', 'CMCC-ESM2', 'CNRM-CM6-1', 'CNRM-ESM2-1', 'CanESM5', 'EC-Earth3', 'EC-Earth3-Veg-LR', 'FGOALS-g3', 'GFDL-CM4', 'GFDL-ESM4', 'GISS-E2-1-G', 'HadGEM3-GC31-LL', 'HadGEM3-GC31-MM', 'IITM-ESM', 'INM-CM4-8', 'INM-CM5-0', 'IPSL-CM6A-LR', 'KACE-1-0-G', 'KIOST-ESM', 'MIROC-ES2L', 'MIROC6', 'MPI-ESM1-2-HR', 'MPI-ESM1-2-LR', 'MRI-ESM2-0', 'NESM3', 'NorESM2-MM', 'TaiESM1', 'UKESM1-0-LL'];

var startDate = ee.Date('1953-01-01');
var endDate = ee.Date('1954-12-31');
var dateRange = ee.DateRange(startDate, endDate);

var filteredCollection = collection.filterDate(dateRange);

var temperatureBand = 'tas';
var precipitationBand = 'pr';

var emptyCollection = ee.ImageCollection([]);

var monthlyMeansCollection = ee.ImageCollection.fromImages(
  ee.List.sequence(1953, 1954).map(function (year) {
    return ee.List.sequence(1, 12).map(function (month) {
      var startDate = ee.Date.fromYMD(year, month, 1);
      var endDate = startDate.advance(1, 'month').advance(-1, 'day');

      var monthlyCollection = filteredCollection
        .filter(ee.Filter.calendarRange(year, year, 'year'))
        .filter(ee.Filter.calendarRange(month, month, 'month'));

      var meanTemperature = monthlyCollection.select(temperatureBand)
                                              .mean().subtract(273)
                                              .rename(['meanTemperature']);
      
      var mp = ee.ImageCollection.fromImages(models.map(function(m) {
        return monthlyCollection.filter(ee.Filter.eq('model', m))
                                .select(precipitationBand)
                                .sum().multiply(1000).multiply(86400).divide(997)
                                .rename('sumPrecipitation');
      }));
      
      // Set the system:time_start property to the start date of the month
      var image = meanTemperature.addBands(mp.select('sumPrecipitation').mean())
                                .set('year', year)
                                .set('month', month)
                                .set('startDate', startDate)
                                .set('endDate', endDate)
                                .set('system:time_start', startDate.millis());

      return image;
    });
  }).flatten()
);


var dateRange = monthlyMeansCollection.reduceColumns(ee.Reducer.minMax(), ['system:time_start']); // Calculate the minimum and maximum time start values in the collection.
var startDate = ee.Date(dateRange.get('min')); // Extract the minimum date from the date range.
var endDate = ee.Date(dateRange.get('max')); // Extract the maximum date from the date range.
print(startDate)
print(endDate)

