var countries = ee.FeatureCollection('FAO/GAUL_SIMPLIFIED_500m/2015/level0');
var country = countries.filter(ee.Filter.eq('ADM0_CODE', 132));

var collection = ee.ImageCollection('NASA/GDDP-CMIP6').filter(ee.Filter.eq('scenario', 'historical'));
var models = ['ACCESS-CM2', 'ACCESS-ESM1-5', 'BCC-CSM2-MR', 'CESM2', 'CESM2-WACCM', 'CMCC-CM2-SR5', 'CMCC-ESM2', 'CNRM-CM6-1', 'CNRM-ESM2-1', 'CanESM5', 'EC-Earth3', 'EC-Earth3-Veg-LR', 'FGOALS-g3', 'GFDL-CM4', 'GFDL-ESM4', 'GISS-E2-1-G', 'HadGEM3-GC31-LL', 'HadGEM3-GC31-MM', 'IITM-ESM', 'INM-CM4-8', 'INM-CM5-0', 'IPSL-CM6A-LR', 'KACE-1-0-G', 'KIOST-ESM', 'MIROC-ES2L', 'MIROC6', 'MPI-ESM1-2-HR', 'MPI-ESM1-2-LR', 'MRI-ESM2-0', 'NESM3', 'NorESM2-MM', 'TaiESM1', 'UKESM1-0-LL'];

var startDate = ee.Date('1950-01-01');
var endDate = ee.Date('2014-12-31');

// Loop over years and export images
for (var year = 1950; year <= 2014; year++) {
  var dateRange = ee.DateRange(ee.Date(year + '-01-01'), ee.Date(year + '-12-31'));
  var filteredCollection = collection.filterDate(dateRange);

  var temperatureBand = 'tas';
  var precipitationBand = 'pr';

  var monthlyMeansCollection = ee.ImageCollection.fromImages(
    ee.List.sequence(year, year).map(function (y) {
      return ee.List.sequence(1, 12).map(function (month) {
        
        var monthlyCollection = filteredCollection
                                  .filter(ee.Filter.calendarRange(y, y, 'year'))
                                  .filter(ee.Filter.calendarRange(month, month, 'month'));

        var meanTemperature = monthlyCollection.select(temperatureBand)
                                               .mean().subtract(273)
                                               .rename(['meanTemperature']);
        
        var mp = ee.ImageCollection.fromImages(models.map(function(m) {
          
          return monthlyCollection.filter(ee.Filter.eq('model', m))
                                  .select(precipitationBand)
                                  .sum().multiply(1000).multiply(86400).divide(997)
                                  .rename('sumPrecipitation');
        }));
        
        return meanTemperature.addBands(mp.select('sumPrecipitation').mean()).set('year', year)
                            .set('month', month)
                            .set('system:time_start', startDate.millis())
                            .set('system:time_end', endDate.millis());
      });
    }).flatten()
  );
print('Monthly Means Collection for year ' + year + ':', monthlyMeansCollection);
  // Assuming you have an ImageCollection named 'monthlyDataCollection'
// with bands 'meanTemperature', 'sumPrecipitation', 'year', and 'month'

// Define a function to convert each image in the collection to a single image
var convertToSingleImage = function(image) {
  // Get year and month properties
  var year = image.get('year');
  var month = image.get('month');

  // Create a unique identifier for the image based on year and month
  var imageId = ee.String('monthly_data_')
    .cat(ee.Number(year).int())
    .cat('_')
    .cat(ee.Number(month).int());

  // Create a single-band image with year and month as properties
  var singleImage = ee.Image(0).set({
    'year': year,
    'month': month,
    'system:index': imageId
  });

  // Add bands from the original image to the single-image
  return singleImage
    .addBands(image.select(['meanTemperature']), ['meanTemperature'])
    .addBands(image.select(['sumPrecipitation']), ['sumPrecipitation']);
};

// Map over the ImageCollection to convert each image to a single image
var singleImages = monthlyMeansCollection.map(convertToSingleImage);

// Print the resulting ImageCollection with single images
print('Single Images Collection:', singleImages);

// Optionally, visualize one of the single images
var sampleImage = singleImages.first();
Map.addLayer(sampleImage, {bands: ['meanTemperature'], min: -30, max: 30, palette: ['blue', 'white', 'red']}, 'Sample Image');

}