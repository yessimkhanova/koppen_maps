// Classification 
var nhemi=ee.Image.pixelLonLat().select('latitude').gt(0);
function koppenClass(image) {
  var mintemp=image.select('mintemp');
  var maxtemp=image.select('maxtemp');
  var avgtemp=image.select('avgtemp');
  var tenplus=image.select('tenplusmonths');
  var minprecip=image.select('minprecip');
  var maxprecip=image.select('maxprecip');
  var minsprecip=image.select('minsprecip').multiply(nhemi)
                          .add(image.select('minwprecip').multiply(nhemi.not()));
  var maxsprecip=image.select('maxsprecip').multiply(nhemi)
                          .add(image.select('maxwprecip').multiply(nhemi.not()));
  var minwprecip=image.select('minwprecip').multiply(nhemi)
                          .add(image.select('minsprecip').multiply(nhemi.not()));
  var maxwprecip=image.select('maxwprecip').multiply(nhemi)
                          .add(image.select('maxsprecip').multiply(nhemi.not()));
  var precip=image.select('totalprecip');
  var monsoonminimum=precip.divide(-25).add(100); // 100-totalprecip/25
  var sprecip=image.select('nsummerprecip');

  // determining which season is the summer and select that half year's precipitation
  var summerprecip=sprecip.multiply(nhemi)
                          .add(precip.subtract(sprecip).multiply(nhemi.not()));
  var summerratio=summerprecip.divide(precip);
  var aridthreshold = avgtemp.multiply(20)
                             .add(summerratio.gt(0.3).and(summerratio.lt(0.7)).multiply(140));
                                            // Group B - Arid climates  
  var B=maxtemp.gt(10).and(aridthreshold.gt(precip)); 
  var W=precip.lt(aridthreshold.multiply(0.5)); 
  var h=avgtemp.gt(18); 
  var BW=B.and(W); 
  var BWh=BW.and(h); 
  var BWk=BW.and(h.not()); 
  var BS=B.and(W.not()); 
  var BSh=BS.and(h); 
  var BSk=BS.and(h.not()); 
                                            // Group A - Tropical climates  
  var A=B.not().and(mintemp.gte(18)); 
  var Af=A.and(minprecip.gte(60)); 
  var Am=A.and(minprecip.lt(60)).and(minprecip.gte(monsoonminimum)); 
  var Aw=A.and(minprecip.lt(60)).and(minprecip.lt(monsoonminimum)); 
  //var As=A.and(minprecip.lt(0.060)).and(minprecip.gt(monsoonminimum));
  
                                            // Group C - Temperate climates  
                                            
  var C=B.not().and(mintemp.gte(0)).and(mintemp.lte(18)).and(maxtemp.gte(10));
  var Cw=C.and(maxsprecip.gte(minwprecip.multiply(10)));
  var Cs=C.and(Cw.not()).and(maxwprecip.gte(minsprecip.multiply(3))).and(minsprecip.lt(40));
  var Cf=C.and(Cw.not()).and(Cs.not());
  
  var Cwa=Cw.and(maxtemp.gt(22)).and(tenplus.gte(4));
  var Cwb=Cw.and(maxtemp.lt(22)).and(tenplus.gte(4));
  //var Cwc=Cw.and(Cwa.not()).and(Cwb.not()).and(tenplus.gte(1)).and(tenplus.lt(4));
  var Cwc=Cw.and(tenplus.gte(1)).and(tenplus.lt(4));
  
  var Csa=Cs.and(maxtemp.gt(22)).and(tenplus.gte(4));
  var Csb=Cs.and(maxtemp.lt(22)).and(tenplus.gte(4));
  //var Csc=Cs.and(Csa.not()).and(Csb.not());
  var Csc=Cs.and(tenplus.gte(1)).and(tenplus.lt(4));
 
  var Cfa=Cf.and(maxtemp.gt(22)).and(tenplus.gte(4)).and(summerprecip.gt(0));
  var Cfb=Cf.and(maxtemp.lt(22)).and(tenplus.gte(4));
  //var Cfc=Cf.and(Cfa.not()).and(Cfb.not());
  var Cfc=Cf.and(tenplus.gte(1)).and(tenplus.lt(4));
                                              
                                              // Group D - Continental climates  
                                            
  var D=B.not().and(C.not()).and(mintemp.lt(0)).and(maxtemp.gt(10));
  var Dw=D.and(maxsprecip.gt(minwprecip.multiply(10)));
  var Ds=D.and(maxwprecip.gt(minsprecip.multiply(3))).and(minsprecip.lt(30));
  var Df=D.and(Dw.not()).and(Ds.not());
  
  var Dfa=Df.and(maxtemp.gt(22)).and(tenplus.gte(4)); 
  var Dfb=Df.and(maxtemp.lte(22)).and(tenplus.gte(4)); 
  var Dfd=Df.and(mintemp.lte(-38)).and(tenplus.lt(4)); 
  var Dfc=Df.and(Dfa.not()).and(Dfb.not()).and(Dfd.not());
  
  var Dwa=Dw.and(maxtemp.gte(22)).and(tenplus.gte(4)); 
  var Dwb=Dw.and(maxtemp.lt(22)).and(tenplus.gte(4)); 
  var Dwd=Dw.and(mintemp.lte(-38)).and(tenplus.lt(4)); 
  var Dwc=Dw.and(Dwa.not()).and(Dwb.not()).and(Dwd.not());
  
  var Dsa=Ds.and(maxtemp.gt(22)).and(tenplus.gte(4)); 
  var Dsb=Ds.and(maxtemp.lt(22)).and(tenplus.gte(4)); 
  var Dsd=Ds.and(mintemp.lte(-38)).and(tenplus.lt(4)); 
  var Dsc=Ds.and(Dsa.not()).and(Dsb.not()).and(Dsd.not()); 
 
                                        // Group E - Polar and alpine climates  
  var EF=maxtemp.lte(0); 
  var ET=maxtemp.gte(0).and(maxtemp.lte(10)); 
  
  var classes=Af.multiply(1)
                .add(Am.multiply(2))
                .add(Aw.multiply(3))
              //.add(As.multiply(4))
                .add(BWh.multiply(5))
                .add(BWk.multiply(6))
                .add(BSh.multiply(7))
                .add(BSk.multiply(8))
                .add(Cwa.multiply(9))
                .add(Cwb.multiply(10))
                .add(Cwc.multiply(11))
                .add(Cfa.multiply(12))
                .add(Cfb.multiply(13))
                .add(Cfc.multiply(14))
                .add(Csa.multiply(15))
                .add(Csb.multiply(16))
                .add(Csc.multiply(17))
                .add(Dwa.multiply(18))
                .add(Dwb.multiply(19))
                .add(Dwc.multiply(20))
                .add(Dwd.multiply(21))
                .add(Dfa.multiply(22))
                .add(Dfb.multiply(23))
                .add(Dfc.multiply(24))
                .add(Dfd.multiply(25))
                .add(Dsa.multiply(26))
                .add(Dsb.multiply(27))
                .add(Dsc.multiply(28))
                .add(Dsd.multiply(29))
                .add(ET.multiply(30))
                .add(EF.multiply(31))
    .rename('zone')
      .set({year:image.get('year'),
      zoneNames: zoneNames
    });
  return classes;
}
