// Function to count how many models predict a specific zone
function countZone(zoneIndex) {
  var matchingImages = koppenCollection.map(function(img) {
    return img.eq(zoneIndex).rename('count');
  });

  return matchingImages
    .reduce(ee.Reducer.sum())
    .rename('count');
}

