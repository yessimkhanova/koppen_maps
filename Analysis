  // If the month of the end date is not December, advance it by one year and set the month to December.
  // Otherwise, keep the end date as it is.

// Define a mapping for different environmental variables, such as temperature and precipitation
var keyMap = {
  "temperature": {
    "symbol": "t",
    "band": "temperature_2m"
  },
  "precipitation": {
    "symbol": "p",
    "band": "total_precipitation_sum"
  }
};

// Create a function to generate an ImageCollection with calculations
function createImageCollection(startDate, endDate, args){
  
  var listOfImages = []; // Initialize an empty array to store individual images.
  
  var filteredCollection = collection.filter(ee.Filter.calendarRange(startDate, endDate, 'year')); // Filter the collection based on the specified date range.
  var selectedImage = filteredCollection.select(args.band).toBands(); // Select the specified band(s) from the keyMap configuration and convert them to bands.
 
  // Loop through each year in the specified date range
var years = ee.List.sequence(startDate.get('year').getInfo(), endDate.get('year').getInfo()); // Generate a list of band names for each month.
  
  var listOfDim = []; // Initialize an empty array to store band names.
    for (var i = 1; i <= 12; i++) { // Loop from 1 to 12 (representing months) and push new band names to the array.
          listOfDim.push(args.symbol + i); // Each band name is formed by concatenating the symbol from args
                                          // (which is derived from the keyMap configuration) and the current value of i.
    }
  



years.getInfo().forEach(function (year) {
  var startBand = (year - startDate.get('year').getInfo()) * 12;
  var endBand = startBand + 11;
    
    
    var yearImage = selectedImage.select(ee.List.sequence(startBand, endBand)); // Select bands corresponding to the current year.
        yearImage = yearImage.rename(listOfDim); // Rename bands with the generated list of dimension names.
          
          // Additional calculations for temperature ('t') and precipitation ('p')
          if (args.symbol == 't') { // Check if the symbol from the arguments (args.symbol) is equal to 't'
                                    // The argument symbol is derived from the keyMap configuration.
                                    // This condition is checking whether the data being processed is related to temperature ('t').
                                    // If true, additional calculations for temperature will be performed.
                                    // Rename temperature bands from generic names to more meaningful names ('t1' to 't12') for better interpretation
                                    // Correspondence: 't1' represents January, 't2' represents February, ..., 't12' represents December
            
            // Calculate the average temperature for each pixel across all months in the year
            var avgT = yearImage.reduce(ee.Reducer.mean())
                                .subtract(273) // Convert from Kelvin to Celsius
                                .rename('avgtemp'); // Rename the resulting band as 'avgtemp'
            
            // Calculate the minimum temperature for each pixel across all months in the year
            var minT = yearImage.reduce(ee.Reducer.min())
                                .subtract(273) // Convert from Kelvin to Celsius
                                .rename('mintemp'); // Rename the resulting band as 'mintemp'
            
            // Calculate the maximum temperature for each pixel across all months in the year
            var maxT = yearImage.reduce(ee.Reducer.max())
                                .subtract(273) // Convert from Kelvin to Celsius
                                .rename('maxtemp'); // Rename the resulting band as 'maxtemp'
            
            // Count the number of months where the temperature is greater than 10 degrees Celsius
            var monthsGreaterThan10 = yearImage.gt(10)
                                                .reduce('sum') // Sum the number of occurrences
                                                .rename('tenplusmonths'); // Rename the resulting band as 'tenplusmonths'
            
            // Add the calculated temperature bands to the original image
            yearImage = yearImage.addBands([avgT, minT, maxT, monthsGreaterThan10]);
          }
          
          // Additional calculations precipitation ('p')
          if (args.symbol == 'p') { // Check if the symbol from the arguments (args.symbol) is equal to 'p'
                                    // The argument symbol is derived from the keyMap configuration.
                                    // This condition is checking whether the data being processed is related to precipitation ('p').
                                    // If true, additional calculations for precipitation will be performed.
                                    // Rename precipitation bands from generic names to more meaningful names ('p1' to 'p12') for better interpretation
                                    // Correspondence: 'p1' represents January, 'p2' represents February, ..., 'p12' represents December
            
            // Calculate the total precipitation for each pixel across all months in the year and convert to millimeters
            var totalP = yearImage.reduce(ee.Reducer.sum())
                                  .multiply(1000) // Convert from meters to millimeters
                                  .rename('totalprecip'); // Rename the resulting band as 'totalprecip'
            
            // Calculate the minimum precipitation for each pixel across all months in the year and convert to millimeters
            var minP = yearImage.reduce(ee.Reducer.min())
                                .multiply(1000) // Convert from meters to millimeters
                                .rename('minprecip'); // Rename the resulting band as 'minprecip'
            
            // Calculate the maximum precipitation for each pixel across all months in the year and convert to millimeters
            var maxP = yearImage.reduce(ee.Reducer.max())
                                .multiply(1000) // Convert from meters to millimeters
                                .rename('maxprecip'); // Rename the resulting band as 'maxprecip'
            
            // Calculate the summer precipitation (months 4-9) for each pixel in the year and convert to millimeters
            var summerP = yearImage.select(['p4','p5','p6', 'p7', 'p8', 'p9'])
                                   .reduce('sum') // Sum the precipitation for selected months (April to September)
                                   .multiply(1000) // Convert from meters to millimeters
                                   .rename('nsummerprecip'); // Rename the resulting band as 'nsummerprecip'
            
            // Calculate the winter precipitation (months 10-3) for each pixel in the year and convert to millimeters
            var winterP = yearImage.select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
                                   .reduce('sum') // Sum the precipitation for selected months (October to March)
                                   .multiply(1000) // Convert from meters to millimeters
                                   .rename('winterprecip'); // Rename the resulting band as 'winterprecip'
                                
            // Calculate the maximum winter precipitation for each pixel in the year and convert to millimeters
            var maxWinterP = yearImage.select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
                                      .reduce('max') // Find the maximum precipitation for selected months (October to March)
                                      .multiply(1000) // Convert from meters to millimeters
                                      .rename('maxwprecip'); // Rename the resulting band as 'maxwprecip'
            
            // Calculate the minimum winter precipitation for each pixel in the year and convert to millimeters
            var minWinterP = yearImage.select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
                                      .reduce('min') // Find the minimum precipitation for selected months (October to March)
                                      .multiply(1000) // Convert from meters to millimeters
                                      .rename('minwprecip'); // Rename the resulting band as 'minwprecip'
            
            // Calculate the maximum summer precipitation for each pixel in the year and convert to millimeters
            var maxSummerP = yearImage.select(['p4','p5','p6', 'p7', 'p8', 'p9'])
                                      .reduce('max') // Find the maximum precipitation for selected months (April to September)
                                      .multiply(1000) // Convert from meters to millimeters
                                      .rename('maxsprecip'); // Rename the resulting band as 'maxsprecip'
            
            // Calculate the minimum summer precipitation for each pixel in the year and convert to millimeters
            var minSummerP = yearImage.select(['p4','p5','p6', 'p7', 'p8', 'p9'])
                                      .reduce('min') // Find the minimum precipitation for selected months (April to September)
                                      .multiply(1000) // Convert from meters to millimeters
                                      .rename('minsprecip'); // Rename the resulting band as 'minsprecip'
            
            // Add the calculated precipitation bands to the original image
            yearImage = yearImage.addBands([totalP, minP, maxP, summerP, winterP, maxWinterP, minWinterP, maxSummerP, minSummerP]);

          }
          
          yearImage = yearImage.set('year', year); // Set the 'year' property and add the current year image to the list.
          listOfImages.push(yearImage); // Add the current yearImage to the listOfImages array.
      });
        
        return ee.ImageCollection.fromImages(listOfImages); // Create and return an ImageCollection from the list of generated images
  }
  
// Call the createImageCollection function
var resultTemperatureCollection = createImageCollection(startDate, endDate, keyMap.temperature);
print(resultTemperatureCollection)

// Call the createImageCollection function
var resultPrecipitationCollection = createImageCollection(startDate, endDate, keyMap.precipitation);
print(resultPrecipitationCollection)

  
