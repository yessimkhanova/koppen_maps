function classificateImage(startYear, endYear) {
  
  // Filter yearly images by selected year range
  var filteredYearlyImages = yearlyImages
    .filter(ee.Filter.gte('year', startYear))
    .filter(ee.Filter.lte('year', endYear));
  
  // Average all normal yearly bands
  var meanYearlyImages = filteredYearlyImages.mean();
  
  // Long-term monthly precipitation means for this selected period
  var longTermMonthlyMeanP = filteredYearlyImages
    .select([
      'p1', 'p2', 'p3', 'p4', 'p5', 'p6',
      'p7', 'p8', 'p9', 'p10', 'p11', 'p12'
    ])
    .mean();

  // Correct seasonal precipitation extremes
  var maxWinterP = longTermMonthlyMeanP
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.max())
    .rename('maxwprecip');

  var minWinterP = longTermMonthlyMeanP
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.min())
    .rename('minwprecip');

  var maxSummerP = longTermMonthlyMeanP
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.max())
    .rename('maxsprecip');

  var minSummerP = longTermMonthlyMeanP
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.min())
    .rename('minsprecip');

  // Add required bands before Koppen classification
  var finalYearlyImages = meanYearlyImages.addBands([
    maxWinterP,
    minWinterP,
    maxSummerP,
    minSummerP
  ]);

  var classification = koppenClass(finalYearlyImages);

  return classification;
}


