function classificateImageSSP245(startYear, endYear) {
  
  // Filter yearly images by selected year range
  var filteredYearlyImagesSSP245 = yearlyImagesssp245
    .filter(ee.Filter.gte('year', startYear))
    .filter(ee.Filter.lte('year', endYear));
  
  // Average all normal yearly bands
  var meanYearlyImagesSSP245 = filteredYearlyImagesSSP245.mean();
  
  // Long-term monthly precipitation means for this selected period
  var longTermMonthlyMeanPSSP245 = filteredYearlyImagesSSP245
    .select([
      'p1', 'p2', 'p3', 'p4', 'p5', 'p6',
      'p7', 'p8', 'p9', 'p10', 'p11', 'p12'
    ])
    .mean();

  // Correct seasonal precipitation extremes
  var maxWinterPSSP245 = longTermMonthlyMeanPSSP245
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.max())
    .rename('maxwprecip');

  var minWinterPSSP245 = longTermMonthlyMeanPSSP245
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.min())
    .rename('minwprecip');

  var maxSummerPSSP245 = longTermMonthlyMeanPSSP245
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.max())
    .rename('maxsprecip');

  var minSummerPSSP245 = longTermMonthlyMeanPSSP245
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.min())
    .rename('minsprecip');

  // Add required bands before Koppen classification
  var finalYearlyImagesSSP245 = meanYearlyImagesSSP245.addBands([
    maxWinterPSSP245,
    minWinterPSSP245,
    maxSummerPSSP245,
    minSummerPSSP245
  ]);

  var classificationSSP245 = koppenClass(finalYearlyImagesSSP245);

  return classificationSSP245;
}

