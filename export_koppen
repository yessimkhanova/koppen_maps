function classificateImage(startDate, endDate) {
  
  // Create an image collection for temperature data between startDate and endDate
  var tempImage = createImageCollection(startDate, endDate, keyMap.temperature);

  // Create an image collection for precipitation data between startDate and endDate
  var precipImage = createImageCollection(startDate, endDate, keyMap.precipitation);

  // Calculate the mean temperature image from the temperature image collection
  var tempMeanImage = tempImage.mean();

  // Calculate the mean precipitation image from the precipitation image collection
  var precipMeanImage = precipImage.mean();

  // ------------------------------------------------------------------
  // Corrected seasonal precipitation extremes
  // These are derived from the long-term monthly mean precipitation image
  // ------------------------------------------------------------------

  var maxWinterP = precipMeanImage
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.max())
    .multiply(1000)
    .rename('maxwprecip');

  var minWinterP = precipMeanImage
    .select(['p10', 'p11', 'p12', 'p1', 'p2', 'p3'])
    .reduce(ee.Reducer.min())
    .multiply(1000)
    .rename('minwprecip');

  var maxSummerP = precipMeanImage
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.max())
    .multiply(1000)
    .rename('maxsprecip');

  var minSummerP = precipMeanImage
    .select(['p4', 'p5', 'p6', 'p7', 'p8', 'p9'])
    .reduce(ee.Reducer.min())
    .multiply(1000)
    .rename('minsprecip');

  // Combine precipitation, temperature, and corrected seasonal bands
  var finalYearlyImage = precipMeanImage
    .addBands(tempMeanImage)
    .addBands([
      maxWinterP,
      minWinterP,
      maxSummerP,
      minSummerP
    ]);

  // Perform climate zone classification
  var classification = koppenClass(finalYearlyImage);

  return classification;
}

